{
  "name": "nest-temporal",
  "version": "0.2.0",
  "description": "NestJS integration for Temporal.io — decorator-based activity registration, auto-discovery workers, and dynamic module configuration inspired by @nestjs/bullmq",
  "author": "CenterSeat",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "llms.txt",
    "llms-full.txt"
  ],
  "scripts": {
    "build": "npx tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest --passWithNoTests"
  },
  "keywords": [
    "nestjs",
    "temporal",
    "temporalio",
    "workflow",
    "orchestration",
    "activities",
    "worker",
    "decorator",
    "microservices"
  ],
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@temporalio/client": "^1.9.0 || ^1.10.0 || ^1.11.0",
    "@temporalio/worker": "^1.9.0 || ^1.10.0 || ^1.11.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0"
  },
  "peerDependenciesMeta": {
    "@temporalio/worker": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@temporalio/client": "^1.11.0",
    "@temporalio/worker": "^1.11.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  }
}
